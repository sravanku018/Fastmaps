<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Outer pulse ring (animated) -->
    <item>
        <shape android:shape="oval">
            <solid android:color="#402196F3" />
            <size android:width="48dp" android:height="48dp" />
        </shape>
    </item>
    <!-- Middle ring -->
    <item
        android:left="6dp" android:top="6dp"
        android:right="6dp" android:bottom="6dp">
        <shape android:shape="oval">
            <solid android:color="#802196F3" />
            <size android:width="36dp" android:height="36dp" />
        </shape>
    </item>
    <!-- Inner blue dot -->
    <item
        android:left="12dp" android:top="12dp"
        android:right="12dp" android:bottom="12dp">
        <shape android:shape="oval">
            <solid android:color="#FF2196F3" />
            <stroke android:width="2dp" android:color="#FFFFFFFF" />
            <size android:width="24dp" android:height="24dp" />
        </shape>
    </item>
</layer-list>
