<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Outer pulse (will be animated via code) -->
    <item android:id="@+id/pulse_ring">
        <shape android:shape="oval">
            <solid android:color="#302196F3" />
            <size android:width="64dp" android:height="64dp" />
        </shape>
    </item>
    <!-- Blue dot body -->
    <item
        android:left="16dp" android:top="16dp"
        android:right="16dp" android:bottom="16dp">
        <shape android:shape="oval">
            <solid android:color="#FF2196F3" />
            <stroke android:width="3dp" android:color="#FFFFFFFF" />
            <size android:width="32dp" android:height="32dp" />
        </shape>
    </item>
    <!-- White center -->
    <item
        android:left="22dp" android:top="22dp"
        android:right="22dp" android:bottom="22dp">
        <shape android:shape="oval">
            <solid android:color="#FFFFFFFF" />
            <size android:width="20dp" android:height="20dp" />
        </shape>
    </item>
</layer-list>
